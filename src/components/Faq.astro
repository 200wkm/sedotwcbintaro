<style is:global>
/* FAQ */
.faq{background:#F8F8F8;padding:80px 0}
.faq h2{font-family:'Poppins',sans-serif;font-size:40px;font-weight:700;color:#000;text-align:center;margin-bottom:10px;padding-left:15px;border-left:3px solid #ff7f50;display:inline-block}
